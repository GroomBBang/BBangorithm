from collections import defaultdict

def solution():
    text = input()
    target = input()
    dist = int(input())

    n = len(text)
    m = len(target)

    char_indices = defaultdict(list)
    for i, char in enumerate(text):
        char_indices[char].append(i)

    dp = [set() for _ in range(m)]

    # 타겟 글자의 첫번째 글자에 해당하는 인덱스를 전부 가져옴.
    for idx in char_indices[target[0]]:
        dp[0].add(idx)

    for i in range(1, m):
        current_char = target[i]

        # 이전 인덱스에서 설정된 거리 이내에 가능한 원소가 하나라도 있으면 통과
        for curr_idx in char_indices[current_char]:
            for prev_idx in dp[i-1]:
                if 0 < curr_idx - prev_idx <= dist:
                    dp[i].add(curr_idx)
                    break

        if not dp[i]:
            print(0)
            return
        
    print(1 if dp[m-1] else 0)

if __name__ == "__main__":
    solution()
